    "mlp:prototype-acceptance": "node scripts/mlp-prototype-acceptance.mjs",
    "mlp:docs-complete": "npm run mlp:generate-docs && npm run mlp:prototype-acceptance && npm run mlp:route-check",
    "mlp:fast-check": "npm run mlp:review && npm run build",
    "preview": "vite preview --host 0.0.0.0",
    "mlp:framework-sync": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/sync-framework-full.mjs .",
    "mlp:migrate-full": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/migrate-project-full.mjs .",
    "mlp:release": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/mlp-version.mjs release .",
    "mlp:versions": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/mlp-version.mjs list .",
    "mlp:rollback": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/mlp-version.mjs rollback .",
    "mlp:access": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/mlp-access.mjs show .",
    "mlp:runtime-review": "node scripts/mlp-runtime-review.mjs",
    "mlp:route-check": "npm run mlp:fast-check && npm run mlp:runtime-review",
    "mlp:visual-review": "node scripts/mlp-visual-review.mjs",
    "mlp:acceptance": "npm run mlp:route-check && npm run mlp:prototype-acceptance",
    "mlp:visual-acceptance": "npm run mlp:acceptance && npm run mlp:visual-review",
    "mlp:split-modules": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/split-project-modules.mjs .",
    "mlp:visual-snapshot": "node scripts/mlp-visual-review.mjs --snapshot-only",
    "mlp:framework-patch": "node /Users/telace/.codex/skills/mobile-lowfi-prototype/scripts/sync-framework-guards.mjs .",
    "mlp:export-ai": "node scripts/mlp-export-ai-handoff.mjs"
  },
  "dependencies": {
    "@vitejs/plugin-react": "^4.6.0",
    "vite": "^7.2.7",
    "typescript": "^5.9.3",
